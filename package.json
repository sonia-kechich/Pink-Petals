{
  "name": "pink-petals-planner",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Pink Petals Planner — a premium, magical productivity app: luxury planner, self-care journal, habit tracker, and fantasy garden.",
  "author": "Pink Petals Planner",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run typecheck && npm run test:run && npm run build",
    "generate:icons": "node scripts/generate-icons.mjs",
    "cap:add": "cap add android",
    "cap:sync": "npm run build && cap sync android",
    "cap:open": "cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@supabase/supabase-js": "^2.110.1",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.3.19",
    "lucide-react": "^0.417.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "postcss": "^8.4.40",
    "prettier": "^3.9.4",
    "puppeteer-core": "^25.2.1",
    "sharp": "^0.33.4",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.3.5",
    "vite-plugin-pwa": "^0.20.1",
    "vitest": "^4.1.9"
  }
}
